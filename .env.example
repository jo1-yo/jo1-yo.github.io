# Contact-form SMS backend (Vercel + Twilio)
# Add these in Vercel → Project → Settings → Environment Variables.
# DO NOT commit real values. Your phone number lives ONLY here — never in the site code.

# From console.twilio.com (Account Info)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Your Twilio phone number (the sender), in E.164 format
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# The phone that receives the messages (your personal number), in E.164 format
DESTINATION_PHONE=+1XXXXXXXXXX
